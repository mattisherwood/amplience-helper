{
  "_comment": "Configuration for tcort/markdown-link-check used by the check-links workflow. Tweak ignorePatterns and aliveStatusCodes if a real link is being incorrectly flagged.",
  "ignorePatterns": [
    {"pattern": "^https?://localhost"},
    {"pattern": "^https?://127\\."}
  ],
  "aliveStatusCodes": [200, 206, 301, 302, 403, 999],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "httpHeaders": [
    {
      "urls": ["https://chromewebstore.google.com/", "https://github.com/"],
      "headers": {
        "User-Agent": "Mozilla/5.0 (compatible; markdown-link-check/CI)"
      }
    }
  ]
}
