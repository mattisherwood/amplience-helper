{
  "manifest_version": 3,
  "name": "Amplience Helper",
  "version": "2.1.0",
  "description": "A suite of tools bundled in a browser extension to help everyday Amplience users create content at the speed of ideas.",
  "permissions": ["storage", "alarms"],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Amplience Helper"
  },
  "background": {
    "service_worker": "background-update.js"
  },
  "host_permissions": [
    "https://app.amplience.net/content*",
    "https://app.amplience.net/content-studio/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.amplience.net/content-studio/*"],
      "css": ["modules/flows-filter/flows-filter.css"],
      "js": [
        "modules/flows-filter/utils.js",
        "modules/flows-filter/flows-filter.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.amplience.net/content*"],
      "js": ["modules/hotkeys/hotkeys.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.amplience.net/*"],
      "css": ["modules/style-patches/style-patches.css"],
      "js": ["modules/style-patches/style-patches.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/amplience-16x16.png",
    "32": "icons/amplience-32x32.png",
    "96": "icons/amplience-96x96.png"
  }
}
